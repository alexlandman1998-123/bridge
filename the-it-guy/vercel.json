{
  "buildCommand": "npm run build:guarded",
  "env": {
    "VITE_DOCUMENT_TITLE": "Bridge Nine"
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/release-manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "app.bridgenine.co.za"
        }
      ],
      "destination": "https://app.arch9.co.za/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|brand/|favicon(?:-[^/]+)?\\.(?:png|svg|ico)|arch9-launch-preview\\.png|vite\\.svg).*)",
      "destination": "/index.html"
    }
  ]
}
